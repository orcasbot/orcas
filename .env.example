# ============================================
# BASE TRADER — Environment Configuration
# ============================================

# Server
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=BaseTraderBot

# Base Chain
BASE_RPC_URL=https://mainnet.base.org
# Optional: use Alchemy/Infura for better reliability
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Claude AI (powers the conversational bot)
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024

# Database (PostgreSQL — Neon, Supabase, or local)
DATABASE_URL=postgresql://user:pass@host:5432/basetrader?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@host:5432/basetrader?sslmode=require

# Redis (Upstash — optional but recommended)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Security
JWT_SECRET=your_jwt_secret_min_16_chars
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=your_64_char_hex_key_for_wallet_encryption_32_bytes

# Treasury Wallet (receives 2% platform fee)
TREASURY_WALLET=0xYourTreasuryAddress

# DEX Aggregators (optional — works without but may rate-limit)
ZEROX_API_KEY=your_0x_api_key
ONEINCH_API_KEY=your_1inch_api_key

# Safety
GOPLUS_API_URL=https://api.gopluslabs.io/api/v1

# Error Reporting (optional)
ERROR_REPORT_BOT_TOKEN=your_error_bot_token
ERROR_REPORT_CHAT_ID=your_chat_id

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Trust proxy (set to true behind nginx/cloudflare)
TRUST_PROXY=false
