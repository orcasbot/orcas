generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  // Telegram
  telegramId       String? @unique @map("telegram_id")
  telegramUsername String? @map("telegram_username")

  // Email (for account recovery)
  email String? @unique

  // Subscription
  isPremium    Boolean   @default(false) @map("is_premium")
  premiumUntil DateTime? @map("premium_until")

  isActive               Boolean  @default(true) @map("is_active")
  isPaused               Boolean  @default(false) @map("is_paused")
  hasCompletedOnboarding Boolean  @default(false) @map("has_completed_onboarding")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  wallets          Wallet[]
  settings         UserSettings?
  trades           Trade[]
  premiumPayments  PremiumPayment[]
  alphaGroups      AlphaGroup[]
  scheduledActions ScheduledAction[]
  monitors         Monitor[]

  @@map("users")
}

model Wallet {
  id           String     @id @default(uuid())
  userId       String     @map("user_id")
  address      String
  encryptedKey String     @map("encrypted_key") // AES-256-GCM encrypted private key
  isPrimary    Boolean    @default(false) @map("is_primary")
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@unique([userId])
  @@map("wallets")
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique @map("user_id")

  // Buy amounts in USD (converted to ETH at trade time)
  ethBuyAmountUsd Decimal @default(5) @map("eth_buy_amount_usd") @db.Decimal(18, 6)

  // Safety settings
  maxSlippageBps  Int     @default(500) @map("max_slippage_bps") // 5% = 500 bps
  dailyLimitUsd   Decimal @default(100) @map("daily_limit_usd") @db.Decimal(18, 2)
  minLiquidityUsd Decimal @default(5000) @map("min_liquidity_usd") @db.Decimal(18, 2)
  maxRiskScore    Int     @default(60) @map("max_risk_score")

  // Low balance alert threshold (USD)
  lowBalanceThresholdUsd Decimal @default(10) @map("low_balance_threshold_usd") @db.Decimal(18, 2)

  // Telegram notifications
  tgNotificationsEnabled Boolean @default(true) @map("tg_notifications_enabled")
  tgNotifyTradeConfirmed Boolean @default(true) @map("tg_notify_trade_confirmed")
  tgNotifyTradeFailed    Boolean @default(true) @map("tg_notify_trade_failed")
  tgNotifyTradeRejected  Boolean @default(true) @map("tg_notify_trade_rejected")
  tgNotifyLowBalance     Boolean @default(true) @map("tg_notify_low_balance")

  // Auto-sell TP/SL — always active when set; null = disabled
  autoSellEnabled Boolean @default(false) @map("auto_sell_enabled")
  takeProfitPct   Decimal? @map("take_profit_pct") @db.Decimal(5, 2)
  stopLossPct     Decimal? @map("stop_loss_pct") @db.Decimal(5, 2)

  // Alpha copy-trading
  alphaPaused Boolean @default(false) @map("alpha_paused")

  // Sniper window — alpha auto-buy filters
  sniperMaxAgeSecs Int?     @map("sniper_max_age_secs")
  sniperMaxPumpPct Decimal? @map("sniper_max_pump_pct") @db.Decimal(6, 2)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Trade {
  id       String  @id @default(uuid())
  userId   String  @map("user_id")
  walletId String? @map("wallet_id")

  // Token info (Base only)
  tokenAddress String  @map("token_address")
  tokenSymbol  String? @map("token_symbol")
  tokenName    String? @map("token_name")

  // Trade details
  action         TradeAction
  inputCurrency  String?     @map("input_currency") // "ETH" or "USDC"
  amountIn       Decimal     @map("amount_in") @db.Decimal(18, 8)
  amountInUsd    Decimal?    @map("amount_in_usd") @db.Decimal(18, 2)
  amountOut      Decimal?    @map("amount_out") @db.Decimal(18, 8)
  amountOutUsd   Decimal?    @map("amount_out_usd") @db.Decimal(18, 2)
  pricePerToken  Decimal?    @map("price_per_token") @db.Decimal(24, 12)
  slippageActual Decimal?    @map("slippage_actual") @db.Decimal(5, 2)

  // Transaction
  txHash         String   @map("tx_hash")
  txStatus       TxStatus @default(PENDING) @map("tx_status")
  gasFee         Decimal? @map("gas_fee") @db.Decimal(18, 8)
  platformFee    Decimal? @map("platform_fee") @db.Decimal(18, 8)
  platformFeeUsd Decimal? @map("platform_fee_usd") @db.Decimal(18, 2)

  // Token metadata
  tokenDecimals Int? @map("token_decimals")

  // Safety
  riskScore    Int?  @map("risk_score")
  safetyChecks Json? @map("safety_checks")

  // Alpha caller linkage
  alphaGroupId String? @map("alpha_group_id")

  // Errors
  errorMessage String? @map("error_message")
  retryCount   Int     @default(0) @map("retry_count")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  confirmedAt DateTime? @map("confirmed_at")

  user   User    @relation(fields: [userId], references: [id])
  wallet Wallet? @relation(fields: [walletId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([tokenAddress])
  @@index([txStatus])
  @@index([userId, action, txStatus])
  @@map("trades")
}

model PremiumPayment {
  id     String @id @default(uuid())
  userId String @map("user_id")

  amountPaid Decimal @map("amount_paid") @db.Decimal(18, 8) // ETH
  amountUsd  Decimal @map("amount_usd") @db.Decimal(18, 2)

  txHash String        @map("tx_hash")
  status PaymentStatus @default(PENDING)

  startDate DateTime @map("start_date")
  endDate   DateTime @map("end_date")

  createdAt   DateTime  @default(now()) @map("created_at")
  confirmedAt DateTime? @map("confirmed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("premium_payments")
}

model TokenCache {
  address       String
  symbol        String?
  name          String?
  decimals      Int?
  riskScore     Int?     @map("risk_score")
  safetyData    Json?    @map("safety_data")
  liquidityUsd  Decimal? @map("liquidity_usd") @db.Decimal(18, 2)
  isHoneypot    Boolean? @map("is_honeypot")
  lastCheckedAt DateTime @default(now()) @map("last_checked_at")

  @@id([address])
  @@index([lastCheckedAt])
  @@map("token_cache")
}

// Enums
enum WalletType {
  EOA
  CUSTODIAL
}

enum TradeAction {
  BUY
  SELL
}

enum TxStatus {
  PENDING
  SUBMITTED
  CONFIRMED
  FAILED
  REJECTED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

model AlphaGroup {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  groupId        String?  @map("group_id")
  groupUsername  String?  @map("group_username")
  groupHandle    String?  @map("group_handle")
  groupTitle     String?  @map("group_title")
  callerUsername String   @map("caller_username")
  callerId       String?  @map("caller_id")
  isActive       Boolean  @default(true) @map("is_active")
  tradesExecuted Int      @default(0) @map("trades_executed")
  createdAt      DateTime @default(now()) @map("created_at")

  // Per-caller strategy overrides
  buyAmountUsd  Decimal? @map("buy_amount_usd") @db.Decimal(18, 6)
  takeProfitPct Decimal? @map("take_profit_pct") @db.Decimal(5, 2)
  stopLossPct   Decimal? @map("stop_loss_pct") @db.Decimal(5, 2)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, callerUsername, groupUsername])
  @@index([groupId, isActive])
  @@index([userId])
  @@map("alpha_groups")
}

enum ScheduledActionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model ScheduledAction {
  id           String                @id @default(uuid())
  userId       String                @map("user_id")
  action       String
  params       Json
  description  String?
  executeAt    DateTime              @map("execute_at")
  status       ScheduledActionStatus @default(PENDING)
  result       Json?
  errorMessage String?               @map("error_message")
  createdAt    DateTime              @default(now()) @map("created_at")
  executedAt   DateTime?             @map("executed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, executeAt])
  @@index([userId])
  @@map("scheduled_actions")
}

enum MonitorType {
  PRICE_ALERT
  LIMIT_ORDER
  WALLET_TRACK
  DCA
}

enum MonitorStatus {
  WATCHING
  TRIGGERED
  CANCELLED
}

model Monitor {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  type          MonitorType
  status        MonitorStatus @default(WATCHING)
  params        Json
  description   String?
  lastCheckedAt DateTime?     @map("last_checked_at")
  triggeredAt   DateTime?     @map("triggered_at")
  nextRunAt     DateTime?     @map("next_run_at")
  expiresAt     DateTime?     @map("expires_at")
  createdAt     DateTime      @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, lastCheckedAt])
  @@index([userId])
  @@map("monitors")
}
